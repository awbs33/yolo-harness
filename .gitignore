# 모델 가중치 (용량 큰 바이너리 — LFS 또는 별도 공유)
*.pt
*.pth
*.onnx
*.engine

# 파이프라인 출력물
results/

# 입력 이미지 (샘플 제외, 실제 데이터는 별도 공유)
images/*
!images/.gitkeep

# Python 빌드/캐시
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# 가상환경
.venv/
venv/
env/
.env

# 테스트 캐시
.pytest_cache/
.coverage
htmlcov/
.tox/

# 에이전트 워크스페이스 (로컬 전용)
_workspace/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 로컬 설정 (공유 불필요)
.claude/settings.local.json
